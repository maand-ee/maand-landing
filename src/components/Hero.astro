---
import { Image } from 'astro:assets';
import office from '../assets/officePic.jpg';
import java from '../assets/java.svg';
import typescript from '../assets/typescript.svg';
import react from '../assets/react.svg';
import nextjs from '../assets/nextjs.svg';
import vue from '../assets/vue.svg';
import angular from '../assets/angular.svg';
interface Props {
    lang: 'et' | 'en';
}

const { lang} = Astro.props;
---
<section class="mt-8 relative bg-sand mx-2 sm:mx-8 md:mx-12 rounded-3xl overflow-hidden lg:min-h-[80vh]">
    <Image
            src={office}
            alt=""
            class="absolute inset-0 w-full h-full object-cover object-center scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-black/20" />
    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 justify-between container items-center min-h-[60vh] lg:min-h-[80vh]">
        <div class="order-last lg:order-first flex flex-col justify-center">
            <h2 class="text-4xl mt-4 lg:mt-0 sm:text-5xl font-bold mb-4 text-primary text-center md:text-left">
                {lang === 'et' ? 'Õigesti tehtud tarkvara' : 'Software done right'}
            </h2>
            <p class="mb-8 text-primary text-center md:text-left">
                {lang === 'et' ? 'Loome teile parima lahenduse' : 'We build the best solution for you'}
            </p>
            <div class="flex justify-center md:justify-start">
                <a class="bg-primary text-black p-3 px-6 rounded-lg" href="#contact">
                    {lang === 'et' ? 'Võta ühendust' : 'Get in touch'}
                </a>
            </div>
        </div>
    </div>
</section>

<section class="container flex flex-col sm:flex-row sm:space-x-12 items-center my-8 flex-wrap">
    <p>{lang === 'et' ? 'Me räägime sinu keelt:' : 'We speak your language:'}</p>
    <div class="flex justify-between flex-1 gap-4 lg:gap-0 items-center sm:px-16">
        <Image src={java} alt="Java" class="h-8 sm:h-16 w-auto -mr-2" />
        <Image src={typescript} alt="Typescript" class="h-8 sm:h-10 w-auto" />
        <Image src={react} alt="React" class="h-8 sm:h-10 w-auto" />
        <Image src={nextjs} alt="NextJS" class="h-8 sm:h-10 w-auto" />
        <Image src={vue} alt="Vue" class="h-8 sm:h-10 w-auto" />
        <Image src={angular} alt="Angular" class="h-11 sm:h-14 w-auto" />
    </div>
</section>