        <div class="flex flex-col items-center">
            <Image src={andres} alt="Andres Saaremõts" class="w-40 h-40 md:w-48 md:h-48 rounded-full object-cover" />
            <p class="mt-2 font-medium text-center">Aksel Kaasik</p>
