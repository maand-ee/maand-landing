    <h3 class="font-bold text-3xl text-center">
        {lang === 'et' ? 'Meie meeskond' : 'Our team'}
    </h3>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 text-black">
        <div class="flex flex-col items-center">
